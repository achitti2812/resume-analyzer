# Copy to .env: cp .env.example .env
# Local dev only. Vercel provides its own port/runtime.
PORT=9555

# Comma-separated allowed frontend origins.
# Local example:
# CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173
# Production example:
# CORS_ORIGIN=https://your-frontend-site.netlify.app
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Optional URL shown on the backend root page/JSON metadata.
UI_URL=http://localhost:5173

# --- AI: use Google (AI Studio) OR OpenAI (if both set, Google is used) ---
# Get a key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=
# Optional alias for the same key:
# GEMINI_API_KEY=
# Model id (try gemini-2.0-flash, gemini-1.5-flash, or listed in AI Studio)
GOOGLE_AI_MODEL=gemini-2.5-flash-lite

# OpenAI (optional fallback if GOOGLE_API_KEY is empty)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
