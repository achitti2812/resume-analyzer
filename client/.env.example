# Public frontend variables only. Do not put API keys here.
# For local dev, you can leave this unset and use the Vite proxy.
# For Netlify production, set this to your deployed backend base URL.
VITE_API_URL=

# Optional for local dev if your backend proxy target is not http://127.0.0.1:9555
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:9555
